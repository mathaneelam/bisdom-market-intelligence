# AI - Ollama (OpenAI-compatible API)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3

# AI - Ollama Fall Back (optional; used automatically if the primary key fails)
OLLAMA_API_KEY_FALLBACK=

# Database (Supabase PostgreSQL — use asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@project.supabase.co:5432/postgres

# Cache / Queue (Upstash Redis)
REDIS_URL=redis://localhost:6379

# Email delivery (Resend.com)
RESEND_API_KEY=your_resend_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Instagram (for hashtag scraping)
INSTAGRAM_USERNAME=your_instagram_username_here
INSTAGRAM_PASSWORD=your_instagram_password_here
